<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.VideoHelper.Views.CompressVideoPopupCompressionLevelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <SelectorBar
            x:Name="TabSelector"
            Grid.Row="0"
            Margin="16,8,16,0"
            SelectionChanged="TabSelector_SelectionChanged">
            <SelectorBarItem
                x:Name="PresetTab"
                api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/PresetTab"
                IsSelected="True" />
            <SelectorBarItem x:Name="CustomTab" api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/CustomTab" />
        </SelectorBar>

        <Frame
            x:Name="TabFrame"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            IsNavigationStackEnabled="False" />
    </Grid>
</Page>
