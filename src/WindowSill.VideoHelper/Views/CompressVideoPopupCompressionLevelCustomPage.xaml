<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.VideoHelper.Views.CompressVideoPopupCompressionLevelCustomPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Settings  -->
        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollMode="Disabled"
            VerticalScrollMode="Auto">
            <StackPanel
                Margin="24"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <!--  Video Codec  -->
                <ComboBox
                    api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/VideoCodec"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{x:Bind ViewModel.VideoCodecs}"
                    SelectedIndex="{x:Bind ViewModel.SelectedCodecIndex, Mode=TwoWay}" />

                <!--  Quality (CRF)  -->
                <StackPanel Spacing="4">
                    <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/QualityLabel" Style="{StaticResource BodyTextBlockStyle}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider
                            Grid.Column="0"
                            Maximum="51"
                            Minimum="0"
                            SnapsTo="Ticks"
                            TickFrequency="1"
                            Value="{x:Bind ViewModel.Crf, Mode=TwoWay}" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.Crf, Mode=OneWay}" />
                    </Grid>
                </StackPanel>

                <controls:UniformGrid ColumnSpacing="8" RowSpacing="8">
                    <!--  Encoding Speed  -->
                    <ComboBox
                        api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/EncodingSpeed"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.EncodingPresets}"
                        SelectedIndex="{x:Bind ViewModel.SelectedPresetIndex, Mode=TwoWay}" />

                    <!--  Audio Bitrate  -->
                    <ComboBox
                        api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/AudioBitrate"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.AudioBitrates}"
                        SelectedIndex="{x:Bind ViewModel.SelectedAudioBitrateIndex, Mode=TwoWay}" />

                    <!--  Resolution  -->
                    <ComboBox
                        api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/Resolution"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.Resolutions}"
                        SelectedIndex="{x:Bind ViewModel.SelectedResolutionIndex, Mode=TwoWay}" />

                    <!--  Max Frame Rate  -->
                    <ComboBox
                        api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/FrameRate"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.FrameRates}"
                        SelectedIndex="{x:Bind ViewModel.SelectedFrameRateIndex, Mode=TwoWay}" />
                </controls:UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!--  Command Bar  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    api:Uids.Uid="/WindowSill.VideoHelper/CompressVideo/CompressButton"
                    Command="{x:Bind ViewModel.CompressWithCustomSettingsCommand}"
                    ElementSoundMode="FocusOnly"
                    Style="{ThemeResource LargeAccentButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
