<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.VideoHelper.Views.ConvertVideoPopupProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:WindowSill.VideoHelper.Services"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Task List  -->
        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollMode="Disabled"
            VerticalScrollMode="Auto">
            <ItemsControl Margin="24" ItemsSource="{x:Bind ViewModel.Queue.Tasks, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:VideoConversionTaskItem">
                        <Grid Margin="0,0,0,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Status Indicator  -->
                            <Grid
                                Grid.RowSpan="2"
                                Grid.Column="0"
                                Width="24"
                                Height="24"
                                VerticalAlignment="Center">
                                <ProgressRing
                                    Width="20"
                                    Height="20"
                                    IsActive="{x:Bind IsRunning, Mode=OneWay}" />
                                <InfoBadge Style="{StaticResource SuccessIconInfoBadgeStyle}" Visibility="{x:Bind IsSucceeded, Mode=OneWay}" />
                                <InfoBadge Style="{StaticResource CriticalIconInfoBadgeStyle}" Visibility="{x:Bind IsFailed, Mode=OneWay}" />
                            </Grid>

                            <!--  File Name  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis" />

                            <!--  Progress Bar  -->
                            <ProgressBar
                                Grid.Row="1"
                                Grid.Column="1"
                                Maximum="1"
                                Minimum="0"
                                Visibility="{x:Bind IsRunning, Mode=OneWay}"
                                Value="{x:Bind Progress, Mode=OneWay}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Bottom Bar with Cancel Button  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/CancelButton"
                    Command="{x:Bind ViewModel.CancelConversionCommand}"
                    ElementSoundMode="FocusOnly"
                    Style="{ThemeResource LargeButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
