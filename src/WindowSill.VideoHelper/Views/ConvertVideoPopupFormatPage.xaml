<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.VideoHelper.Views.ConvertVideoPopupFormatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalContentAlignment="Stretch"
        HorizontalScrollMode="Disabled"
        VerticalScrollMode="Auto">
        <StackPanel Margin="24" Spacing="8">
            <controls:UniformGrid
                VerticalAlignment="Top"
                ColumnSpacing="8"
                Columns="2"
                RowSpacing="8">
                <api:ShortcutButton
                    Height="64"
                    Command="{x:Bind ViewModel.SelectFormatCommand}"
                    CommandParameter="mp4"
                    Style="{StaticResource LargeShortcutButtonStyle}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatMp4Title" HorizontalAlignment="Center" />
                        <TextBlock
                            api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatMp4Description"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </api:ShortcutButton>
                <api:ShortcutButton
                    Height="64"
                    Command="{x:Bind ViewModel.SelectFormatCommand}"
                    CommandParameter="mkv"
                    Style="{StaticResource LargeShortcutButtonStyle}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatMkvTitle" HorizontalAlignment="Center" />
                        <TextBlock
                            api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatMkvDescription"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </api:ShortcutButton>
                <api:ShortcutButton
                    Height="64"
                    Command="{x:Bind ViewModel.SelectFormatCommand}"
                    CommandParameter="webm"
                    Style="{StaticResource LargeShortcutButtonStyle}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatWebmTitle" HorizontalAlignment="Center" />
                        <TextBlock
                            api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatWebmDescription"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </api:ShortcutButton>
                <api:ShortcutButton
                    Height="64"
                    Command="{x:Bind ViewModel.SelectFormatCommand}"
                    CommandParameter="mov"
                    Style="{StaticResource LargeShortcutButtonStyle}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatMovTitle" HorizontalAlignment="Center" />
                        <TextBlock
                            api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatMovDescription"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </api:ShortcutButton>
                <api:ShortcutButton
                    Height="64"
                    Command="{x:Bind ViewModel.SelectFormatCommand}"
                    CommandParameter="avi"
                    Style="{StaticResource LargeShortcutButtonStyle}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatAviTitle" HorizontalAlignment="Center" />
                        <TextBlock
                            api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatAviDescription"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </api:ShortcutButton>
                <api:ShortcutButton
                    Height="64"
                    Command="{x:Bind ViewModel.SelectFormatCommand}"
                    CommandParameter="gif"
                    Style="{StaticResource LargeShortcutButtonStyle}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatGifTitle" HorizontalAlignment="Center" />
                        <TextBlock
                            api:Uids.Uid="/WindowSill.VideoHelper/ConvertVideo/FormatGifDescription"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </api:ShortcutButton>
            </controls:UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
