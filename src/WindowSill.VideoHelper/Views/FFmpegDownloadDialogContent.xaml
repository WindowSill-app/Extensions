<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.VideoHelper.Views.FFmpegDownloadDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="400"
        Orientation="Vertical"
        Spacing="16">

        <!--  Initial state: Asking user to download  -->
        <StackPanel
            x:Name="PromptPanel"
            Orientation="Vertical"
            Spacing="12"
            Visibility="Visible">

            <TextBlock
                api:Uids.Uid="/WindowSill.VideoHelper/FFmpegDownload/DialogDescription"
                Style="{ThemeResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />

            <StackPanel
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                Orientation="Vertical"
                Spacing="8">

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SegoeFluentIcons}"
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE896;" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="~210 MB"
                        TextWrapping="Wrap" />
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SegoeFluentIcons}"
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE72E;" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        api:Uids.Uid="/WindowSill.VideoHelper/FFmpegDownload/LicenseNotice"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </Grid>
            </StackPanel>

            <HyperlinkButton
                Padding="0"
                Content="ffmpeg.org"
                NavigateUri="https://ffmpeg.org/" />

        </StackPanel>

        <!--  Downloading state  -->
        <StackPanel
            x:Name="DownloadingPanel"
            Orientation="Vertical"
            Spacing="12"
            Visibility="Collapsed">

            <TextBlock
                api:Uids.Uid="/WindowSill.VideoHelper/FFmpegDownload/Downloading"
                Style="{ThemeResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />

            <ProgressBar
                x:Name="DownloadProgressBar"
                IsIndeterminate="False"
                Maximum="100"
                Minimum="0"
                Value="0" />

            <TextBlock
                x:Name="ProgressTextBlock"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="0%" />
        </StackPanel>

        <!--  Error state  -->
        <InfoBar
            x:Name="ErrorInfoBar"
            api:Uids.Uid="/WindowSill.VideoHelper/FFmpegDownload/DownloadFailed"
            IsClosable="False"
            IsOpen="False"
            Severity="Error" />

    </StackPanel>

</UserControl>
