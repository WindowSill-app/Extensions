<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Terminal.Views.CommandSillContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:converters="using:WindowSill.Terminal.Core.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WindowSill.Terminal.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
    </UserControl.Resources>

    <api:SillOrientedGrid
        Margin="{ThemeResource SillCommandContentMargin}"
        ColumnSpacing="8"
        RowSpacing="8">
        <api:SillOrientedGrid.GridLengths>
            <api:SillGridLength Length="Auto" />
            <api:SillGridLength Length="1*" />
            <api:SillGridLength Length="Auto" />
        </api:SillOrientedGrid.GridLengths>

        <Grid>
            <Image x:Name="CompletedImage" Visibility="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Completed'}" />

            <ProgressRing
                x:Name="GlobalProgressRing"
                Width="32"
                Height="32"
                MinWidth="0"
                MinHeight="0"
                IsActive="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Running'}"
                IsIndeterminate="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Running'}"
                Visibility="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Running'}" />
        </Grid>

        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Text="{x:Bind ViewModel.Title, Mode=OneWay}"
            TextTrimming="CharacterEllipsis" />

        <Button
            MaxWidth="24"
            Command="{x:Bind ViewModel.DismissCommand}"
            Content="&#xE711;"
            Style="{StaticResource IconButton}"
            ToolTipService.ToolTip="Dismiss"
            Visibility="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Completed|Canceled|Failed'}" />

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="OrientationStates">

                <VisualState x:Name="HorizontalLarge">
                    <!--  Default state: 32x32 ProgressRing, inner text visible  -->
                </VisualState>

                <VisualState x:Name="HorizontalMedium">
                    <VisualState.Setters>
                        <Setter Target="GlobalProgressRing.Height" Value="16" />
                        <Setter Target="GlobalProgressRing.Width" Value="16" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HorizontalSmall">
                    <VisualState.Setters>
                        <Setter Target="GlobalProgressRing.Height" Value="12" />
                        <Setter Target="GlobalProgressRing.Width" Value="12" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalLarge">
                    <!--  Default state: 32x32 ProgressRing, inner text visible  -->
                </VisualState>

                <VisualState x:Name="VerticalMedium">
                    <!--  Default state: 32x32 ProgressRing, inner text visible  -->
                </VisualState>

                <VisualState x:Name="VerticalSmall">
                    <!--  Default state: 32x32 ProgressRing, inner text visible  -->
                </VisualState>

            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </api:SillOrientedGrid>
</UserControl>
