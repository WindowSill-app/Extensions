<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.Terminal.Views.CommandPopupResultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Padding="24,24,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{x:Bind ViewModel.Script, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
        </Grid>

        <!--  Output  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!--<HyperlinkButton
                    api:Uids.Uid="/WindowSill.Terminal/CommandPopupResultPage/ShowFullOutputLink"
                    Command="{x:Bind ViewModel.ShowFullOutputCommand}"
                    Visibility="{x:Bind ViewModel.IsOutputCapped, Mode=OneWay}" />-->
                <TextBlock
                    FontFamily="Cascadia Mono, Consolas, Courier New"
                    FontSize="12"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.OutputText, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <!--  Command Bar  -->
        <Border
            Grid.Row="2"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    api:Uids.Uid="/WindowSill.Terminal/CommandPopupResultPage/CopyButton"
                    Command="{x:Bind ViewModel.CopyOutputCommand}"
                    Style="{ThemeResource LargeButtonStyle}" />
                <Button
                    Grid.Column="1"
                    api:Uids.Uid="/WindowSill.Terminal/CommandPopupResultPage/RerunButton"
                    Command="{x:Bind ViewModel.RunMenuCommand}"
                    Style="{ThemeResource LargeButtonStyle}" />
                <Button
                    Grid.Column="2"
                    api:Uids.Uid="/WindowSill.Terminal/CommandPopupResultPage/DismissButton"
                    Command="{x:Bind ViewModel.DismissCommand}"
                    Style="{ThemeResource LargeButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
