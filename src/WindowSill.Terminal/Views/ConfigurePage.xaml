<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.Terminal.Views.ConfigurePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:core="using:WindowSill.Terminal.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollMode="Disabled"
            VerticalScrollMode="Auto">
            <StackPanel
                Margin="24"
                HorizontalAlignment="Stretch"
                Spacing="16">
                <!--  Command  -->
                <StackPanel Spacing="4">
                    <TextBlock api:Uids.Uid="/WindowSill.Terminal/ConfigurePage/CommandLabel" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBox
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.CommandText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  Working Directory  -->
                <StackPanel Spacing="4">
                    <TextBlock api:Uids.Uid="/WindowSill.Terminal/ConfigurePage/WorkingDirectoryLabel" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{x:Bind ViewModel.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Grid.Column="1"
                            api:Uids.Uid="/WindowSill.Terminal/ConfigurePage/BrowseButton"
                            Click="BrowseButton_Click"
                            Content="📁" />
                    </Grid>
                </StackPanel>

                <!--  Shell  -->
                <StackPanel Spacing="4">
                    <TextBlock api:Uids.Uid="/WindowSill.Terminal/ConfigurePage/ShellLabel" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{x:Bind ViewModel.AvailableShells}"
                        SelectedItem="{x:Bind ViewModel.SelectedShell, Mode=TwoWay}" />
                </StackPanel>

                <!--  Run as administrator  -->
                <CheckBox
                    api:Uids.Uid="/WindowSill.Terminal/ConfigurePage/RunAsAdminCheckBox"
                    IsChecked="{x:Bind ViewModel.RunAsAdministrator, Mode=TwoWay}" />
            </StackPanel>
        </ScrollViewer>

        <!--  Command Bar  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    api:Uids.Uid="/WindowSill.Terminal/ConfigurePage/RunButton"
                    Command="{x:Bind ViewModel.RunCommand}"
                    ElementSoundMode="FocusOnly"
                    Style="{ThemeResource LargeAccentButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
