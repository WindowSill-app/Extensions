<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowSill.ImageHelper.Views.ConversionProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:api="using:WindowSill.API"
    xmlns:vm="using:WindowSill.ImageHelper.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Conversion Task List -->
        <ScrollViewer
            Grid.Row="0"
            Padding="24">
            <ItemsControl
                ItemsSource="{x:Bind ViewModel.ConversionTasks, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversionTaskItem">
                        <Grid
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Height="64"
                            Padding="16"
                            Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- File Name -->
                            <TextBlock
                                Grid.Column="0"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"/>

                            <!-- Progress Ring -->
                            <ProgressRing
                                Grid.Column="1"
                                Value="0"
                                IsIndeterminate="{x:Bind IsRunning, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"/>

                            <!-- Success Badge -->
                            <InfoBadge
                                Grid.Column="1"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind IsSucceeded, Mode=OneWay}">
                                <InfoBadge.IconSource>
                                    <FontIconSource
                                        FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                        Glyph="&#xE73E;"/>
                                </InfoBadge.IconSource>
                            </InfoBadge>

                            <!-- Failure Badge -->
                            <InfoBadge
                                Grid.Column="1"
                                Background="{ThemeResource SystemFillColorCriticalBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind IsFailed, Mode=OneWay}">
                                <InfoBadge.IconSource>
                                    <FontIconSource
                                        FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                        Glyph="&#xE711;"/>
                                </InfoBadge.IconSource>
                            </InfoBadge>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Command Bar -->
        <Border
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            XYFocusKeyboardNavigation="Enabled"
            Padding="24"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
            <Grid
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <api:ShortcutButton
                    Grid.Column="1"
                    Style="{ThemeResource LargeShortcutButtonStyle}"
                    ElementSoundMode="FocusOnly"
                    Content="{x:Bind ViewModel.CancelButtonText, Mode=OneWay}"
                    Command="{x:Bind ViewModel.CancelCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
