<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.ImageHelper.Views.ConversionProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WindowSill.ImageHelper.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Conversion Task List  -->
        <ScrollViewer Grid.Row="0" Padding="24">
            <ItemsControl ItemsSource="{x:Bind ViewModel.ConversionTasks, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversionTaskItem">
                        <Grid
                            Height="64"
                            Margin="0,0,0,8"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="{ThemeResource ControlCornerRadius}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  File Name  -->
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />

                            <!--  Progress Ring  -->
                            <ProgressRing
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                IsIndeterminate="{x:Bind IsRunning, Mode=OneWay}"
                                Value="0" />

                            <!--  Success Badge  -->
                            <InfoBadge
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                Visibility="{x:Bind IsSucceeded, Mode=OneWay}">
                                <InfoBadge.IconSource>
                                    <FontIconSource FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE73E;" />
                                </InfoBadge.IconSource>
                            </InfoBadge>

                            <!--  Failure Badge  -->
                            <InfoBadge
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{ThemeResource SystemFillColorCriticalBrush}"
                                Visibility="{x:Bind IsFailed, Mode=OneWay}">
                                <InfoBadge.IconSource>
                                    <FontIconSource FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE711;" />
                                </InfoBadge.IconSource>
                            </InfoBadge>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Command Bar  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <api:ShortcutButton
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Content="{x:Bind ViewModel.CancelButtonText, Mode=OneWay}"
                    ElementSoundMode="FocusOnly"
                    Style="{ThemeResource LargeShortcutButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
