<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.ImageHelper.Views.CompressImagePopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WindowSill.ImageHelper.ViewModels"
    Width="350"
    Height="400"
    Closing="SillPopupContent_Closing"
    Opening="SillPopupContent_Opening"
    mc:Ignorable="d">
    <api:SillPopupContent.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter
                x:Key="TrueToCollapsedConverter"
                FalseValue="Visible"
                TrueValue="Collapsed" />
            <converters:FileSizeToFriendlyStringConverter x:Key="FileSizeToFriendlyStringConverter" />
        </ResourceDictionary>
    </api:SillPopupContent.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Task List  -->
        <ScrollViewer Grid.Row="0" Padding="24">
            <ItemsControl ItemsSource="{x:Bind ViewModel.CompressionTasks, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CompressionTaskItem">
                        <Grid
                            Height="64"
                            Margin="0,0,0,8"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="{ThemeResource ControlCornerRadius}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  File Name  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />

                            <!--  Original Size  -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="{x:Bind ByteLengthBeforeCompression, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}" />

                            <!--  Compression Percentage  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind CompressionPercentage, Mode=OneWay}"
                                Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource TrueToCollapsedConverter}}" />

                            <!--  Compressed Size  -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="{x:Bind ByteLengthAfterCompression, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}"
                                Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource TrueToCollapsedConverter}}" />

                            <!--  Progress Ring  -->
                            <ProgressRing
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                IsIndeterminate="{x:Bind IsRunning, Mode=OneWay}"
                                Value="0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Command Bar  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <api:ShortcutButton
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Content="{x:Bind ViewModel.ActionButtonText, Mode=OneWay}"
                    ElementSoundMode="FocusOnly"
                    Style="{ThemeResource LargeShortcutButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</api:SillPopupContent>
