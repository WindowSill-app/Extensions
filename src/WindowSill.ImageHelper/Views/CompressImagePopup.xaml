<?xml version="1.0" encoding="utf-8"?>
<api:SillPopupContent
    x:Class="WindowSill.ImageHelper.Views.CompressImagePopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:api="using:WindowSill.API"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:vm="using:WindowSill.ImageHelper.ViewModels"
    mc:Ignorable="d"
    Width="350"
    Height="400"
    Opening="SillPopupContent_Opening"
    Closing="SillPopupContent_Closing">
    <api:SillPopupContent.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="TrueToCollapsedConverter" TrueValue="Collapsed" FalseValue="Visible"/>
            <converters:FileSizeToFriendlyStringConverter x:Key="FileSizeToFriendlyStringConverter"/>
        </ResourceDictionary>
    </api:SillPopupContent.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Task List -->
        <ScrollViewer
            Grid.Row="0"
            Padding="24">
            <ItemsControl
                ItemsSource="{x:Bind ViewModel.CompressionTasks, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CompressionTaskItem">
                        <Grid
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Height="64"
                            Padding="16"
                            Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- File Name -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"/>

                            <!-- Original Size -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Top"
                                Text="{x:Bind ByteLengthBeforeCompression, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}"/>

                            <!-- Compression Percentage -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Text="{x:Bind CompressionPercentage, Mode=OneWay}"
                                Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource TrueToCollapsedConverter}}"/>

                            <!-- Compressed Size -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Text="{x:Bind ByteLengthAfterCompression, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}"
                                Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource TrueToCollapsedConverter}}"/>

                            <!-- Progress Ring -->
                            <ProgressRing
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Value="0"
                                IsIndeterminate="{x:Bind IsRunning, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Command Bar -->
        <Border
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            XYFocusKeyboardNavigation="Enabled"
            Padding="24"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
            <Grid
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <api:ShortcutButton
                    Grid.Column="1"
                    Style="{ThemeResource LargeShortcutButtonStyle}"
                    ElementSoundMode="FocusOnly"
                    Content="{x:Bind ViewModel.ActionButtonText, Mode=OneWay}"
                    Command="{x:Bind ViewModel.CancelCommand}"/>
            </Grid>
        </Border>
    </Grid>
</api:SillPopupContent>
