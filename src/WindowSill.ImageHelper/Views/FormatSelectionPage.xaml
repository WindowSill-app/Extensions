<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.ImageHelper.Views.FormatSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Format Buttons Grid  -->
        <ScrollViewer
            Grid.Row="0"
            HorizontalContentAlignment="Stretch"
            HorizontalScrollMode="Disabled"
            VerticalScrollMode="Auto">
            <StackPanel Margin="24" Spacing="8">
                <controls:UniformGrid
                    VerticalAlignment="Top"
                    ColumnSpacing="8"
                    RowSpacing="8">
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="Avif"
                        Content="AVIF"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="Bmp"
                        Content="BMP"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="Eps"
                        Content="EPS"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="Gif"
                        Content="GIF"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="Pdf"
                        Content="PDF"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="Tiff"
                        Content="TIFF"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                    <api:ShortcutButton
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        CommandParameter="WebP"
                        Content="WEBP"
                        Style="{StaticResource LargeShortcutButtonStyle}" />
                </controls:UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!--  Bottom Bar with PNG/JPEG  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <api:ShortcutButton
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.ConvertCommand}"
                    CommandParameter="Png"
                    Content="PNG"
                    Style="{StaticResource LargeShortcutButtonStyle}" />
                <api:ShortcutButton
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.ConvertCommand}"
                    CommandParameter="Jpeg"
                    Content="JPEG"
                    Style="{StaticResource LargeShortcutButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
