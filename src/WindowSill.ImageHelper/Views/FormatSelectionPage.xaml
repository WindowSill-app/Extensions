<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowSill.ImageHelper.Views.FormatSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:api="using:WindowSill.API"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Format Buttons Grid -->
        <ScrollViewer
            Grid.Row="0"
            VerticalScrollMode="Auto"
            HorizontalScrollMode="Disabled"
            HorizontalContentAlignment="Stretch">
            <StackPanel
                Spacing="8"
                Margin="24">
                <controls:UniformGrid
                    VerticalAlignment="Top"
                    ColumnSpacing="8"
                    RowSpacing="8">
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="AVIF"
                        CommandParameter="Avif"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="BMP"
                        CommandParameter="Bmp"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="EPS"
                        CommandParameter="Eps"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="GIF"
                        CommandParameter="Gif"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="PDF"
                        CommandParameter="Pdf"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="TIFF"
                        CommandParameter="Tiff"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                    <api:ShortcutButton
                        Style="{StaticResource LargeShortcutButtonStyle}"
                        Content="WEBP"
                        CommandParameter="WebP"
                        Command="{x:Bind ViewModel.ConvertCommand}"/>
                </controls:UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar with PNG/JPEG -->
        <Border
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Padding="24"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
            <Grid
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <api:ShortcutButton
                    Grid.Column="0"
                    Style="{StaticResource LargeShortcutButtonStyle}"
                    Content="PNG"
                    CommandParameter="Png"
                    Command="{x:Bind ViewModel.ConvertCommand}"/>
                <api:ShortcutButton
                    Grid.Column="1"
                    Style="{StaticResource LargeShortcutButtonStyle}"
                    Content="JPEG"
                    CommandParameter="Jpeg"
                    Command="{x:Bind ViewModel.ConvertCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
