<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowSill.InlineTerminal.Views.CommandPopupProgressAndResultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:converters="using:WindowSill.InlineTerminal.Core.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:WindowSill.InlineTerminal.Core.UI"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <converters:EnumToVisibilityConverter
            x:Key="NegationEnumToVisibilityConverter"
            WhenMatch="Collapsed"
            WhenNotMatch="Visible" />
        <converters:BoolToTextWrappingConverter x:Key="BoolToTextWrappingConverter" />
        <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <converters:BoolToScrollModeConverter x:Key="BoolToScrollModeConverter" />
    </Page.Resources>

    <Grid RowSpacing="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid
            Grid.Row="0"
            Margin="24,24,24,0"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.LatestRunStartedAt, Mode=OneWay}" />
        </Grid>

        <!--  Output  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="{x:Bind ViewModel.WordWrapOutput, Mode=OneWay, Converter={StaticResource BoolToScrollBarVisibilityConverter}}"
            HorizontalScrollMode="{x:Bind ViewModel.WordWrapOutput, Mode=OneWay, Converter={StaticResource BoolToScrollModeConverter}}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,0" Orientation="Vertical">
                <TextBlock
                    FontFamily="Cascadia Mono, Consolas, Courier New"
                    FontSize="12"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.OutputText, Mode=OneWay}"
                    TextWrapping="{x:Bind ViewModel.WordWrapOutput, Mode=OneWay, Converter={StaticResource BoolToTextWrappingConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!--  Command Bar  -->
        <Border
            Grid.Row="2"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">
            <Grid>
                <!--  When NOT running  -->
                <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource NegationEnumToVisibilityConverter}, ConverterParameter='Running'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Copy  -->
                    <api:ShortcutButton
                        Grid.Column="0"
                        Command="{x:Bind ViewModel.CopyLatestOutputCommand}"
                        Style="{StaticResource LargeShortcutButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C8;" />
                            <TextBlock api:Uids.Uid="/WindowSill.InlineTerminal/CommandPopupResultPage/CopyButton" />
                        </StackPanel>
                    </api:ShortcutButton>

                    <!--  Re-run / Run (SplitButton with run-and variants)  -->
                    <ui:ShortcutSplitButton
                        Grid.Column="1"
                        Height="40"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Command="{x:Bind ViewModel.RunMenuCommand}"
                        ShortcutBadge="{x:Bind RerunShortcutBadge}">
                        <ui:ShortcutSplitButton.Flyout>
                            <MenuFlyout Placement="TopEdgeAlignedRight">
                                <MenuFlyoutItem api:Uids.Uid="/WindowSill.InlineTerminal/CommandPopupResultPage/RunCopyButton" Command="{x:Bind ViewModel.RunAndCopyMenuCommand}" />
                                <MenuFlyoutItem api:Uids.Uid="/WindowSill.InlineTerminal/CommandPopupResultPage/RunAppendButton" Command="{x:Bind ViewModel.RunAndAppendMenuCommand}" />
                                <MenuFlyoutItem api:Uids.Uid="/WindowSill.InlineTerminal/CommandPopupResultPage/RunReplaceButton" Command="{x:Bind ViewModel.RunAndReplaceMenuCommand}" />
                            </MenuFlyout>
                        </ui:ShortcutSplitButton.Flyout>
                        <Grid>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon Glyph="&#xE76C;" />
                                <TextBlock Text="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}" />
                            </StackPanel>
                            <api:ShortcutBadge
                                x:Name="RerunShortcutBadge"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                OnlyApplyToSillPopup="True" />
                        </Grid>
                    </ui:ShortcutSplitButton>

                    <!--  Dismiss (SplitButton with dismiss others/all)  -->
                    <ui:ShortcutSplitButton
                        Grid.Column="2"
                        Height="40"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Command="{x:Bind ViewModel.DismissCommand}"
                        ShortcutBadge="{x:Bind DismissShortcutBadge}">
                        <ui:ShortcutSplitButton.Flyout>
                            <MenuFlyout
                                x:Name="DismissFlyout"
                                Opening="DismissFlyout_Opening"
                                Placement="TopEdgeAlignedRight" />
                        </ui:ShortcutSplitButton.Flyout>
                        <Grid>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon Glyph="&#xE711;" />
                                <TextBlock api:Uids.Uid="/WindowSill.InlineTerminal/CommandPopupResultPage/DismissButton" />
                            </StackPanel>
                            <api:ShortcutBadge
                                x:Name="DismissShortcutBadge"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                OnlyApplyToSillPopup="True" />
                        </Grid>
                    </ui:ShortcutSplitButton>
                </Grid>

                <!--  When running  -->
                <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.State, Mode=OneWay, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Running'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ProgressRing
                        Grid.Column="0"
                        Width="24"
                        Height="24"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        IsActive="True" />
                    <api:ShortcutButton
                        Grid.Column="1"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Style="{StaticResource LargeShortcutButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE711;" />
                            <TextBlock api:Uids.Uid="/WindowSill.InlineTerminal/CommandPopupResultPage/CancelButton" />
                        </StackPanel>
                    </api:ShortcutButton>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
