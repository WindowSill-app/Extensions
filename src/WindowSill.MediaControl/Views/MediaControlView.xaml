<UserControl
    x:Class="WindowSill.MediaControl.Views.MediaControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:controls="using:WindowSill.MediaControl.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToObjectConverter
            x:Key="IsPlayingToGlyphConverter"
            FalseValue="F1 M 17.24 10.48 C 17.453333 10.613333 17.633331 10.799999 17.779999 11.039999 C 17.926666 11.28 18 11.533333 18 11.799999 C 18 12.066667 17.926666 12.32 17.779999 12.559999 C 17.633331 12.799999 17.453333 12.986667 17.24 13.12 L 7.24 18.599998 C 7 18.733334 6.746666 18.799999 6.48 18.799999 C 6.213333 18.799999 5.966666 18.733334 5.74 18.599998 C 5.513333 18.466667 5.333333 18.279999 5.2 18.039999 C 5.066667 17.799999 5 17.546665 5 17.279999 L 5 6.32 C 5 6.053333 5.066667 5.799999 5.2 5.559999 C 5.333333 5.32 5.513333 5.133333 5.74 5 C 5.966666 4.866667 6.213333 4.799999 6.48 4.799999 C 6.746666 4.799999 7 4.866667 7.24 5 Z M 16.719999 12.24 C 16.906666 12.133333 17 11.986667 17 11.799999 C 17 11.613333 16.906666 11.466667 16.719999 11.36 L 6.76 5.879999 C 6.573333 5.773333 6.4 5.766666 6.24 5.86 C 6.08 5.953334 6 6.106668 6 6.32 L 6 17.279999 C 6 17.493332 6.08 17.646666 6.24 17.74 C 6.4 17.833332 6.573333 17.826666 6.76 17.719999 Z "
            TrueValue="F1 M 5 3.799999 C 4.44 3.799999 3.966666 3.993334 3.58 4.379999 C 3.193333 4.766666 3 5.24 3 5.799999 L 3 17.799999 C 3 18.360001 3.193333 18.833332 3.58 19.219999 C 3.966666 19.606667 4.44 19.799999 5 19.799999 L 7 19.799999 C 7.559999 19.799999 8.033333 19.606667 8.42 19.219999 C 8.806666 18.833332 9 18.360001 9 17.799999 L 9 5.799999 C 9 5.24 8.806666 4.766666 8.42 4.379999 C 8.033333 3.993334 7.559999 3.799999 7 3.799999 Z M 4 5.799999 C 4 5.533333 4.1 5.299999 4.3 5.1 C 4.5 4.9 4.733333 4.799999 5 4.799999 L 7 4.799999 C 7.266666 4.799999 7.5 4.9 7.7 5.1 C 7.9 5.299999 8 5.533333 8 5.799999 L 8 17.799999 C 8 18.066666 7.9 18.299999 7.7 18.5 C 7.5 18.699999 7.266666 18.799999 7 18.799999 L 5 18.799999 C 4.733333 18.799999 4.5 18.699999 4.3 18.5 C 4.1 18.299999 4 18.066666 4 17.799999 Z M 13 3.799999 C 12.439999 3.799999 11.966665 3.993334 11.58 4.379999 C 11.193333 4.766666 11 5.24 11 5.799999 L 11 17.799999 C 11 18.360001 11.193333 18.833332 11.58 19.219999 C 11.966665 19.606667 12.439999 19.799999 13 19.799999 L 15 19.799999 C 15.559999 19.799999 16.033333 19.606667 16.42 19.219999 C 16.806667 18.833332 17 18.360001 17 17.799999 L 17 5.799999 C 17 5.24 16.806667 4.766666 16.42 4.379999 C 16.033333 3.993334 15.559999 3.799999 15 3.799999 Z M 12 5.799999 C 12 5.533333 12.1 5.299999 12.3 5.1 C 12.499999 4.9 12.733332 4.799999 13 4.799999 L 15 4.799999 C 15.266665 4.799999 15.499999 4.9 15.7 5.1 C 15.9 5.299999 16 5.533333 16 5.799999 L 16 17.799999 C 16 18.066666 15.9 18.299999 15.7 18.5 C 15.499999 18.699999 15.266665 18.799999 15 18.799999 L 13 18.799999 C 12.733332 18.799999 12.499999 18.699999 12.3 18.5 C 12.1 18.299999 12 18.066666 12 17.799999 Z " />

        <!--
            When HasArtistName is true → RowSpan = 1 (song on top, artist below).
            When HasArtistName is false → RowSpan = 2 (song centered).
        -->
        <converters:BoolToObjectConverter
            x:Key="ArtistRowSpanConverter"
            FalseValue="2"
            TrueValue="1" />
    </UserControl.Resources>

    <Grid>
        <api:SillOrientedStackPanel
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Spacing="8">

            <!--  Thumbnail and song/artist titles  -->
            <Grid
                x:Name="ThumbnailAndTitlesGrid"
                Width="190"
                Background="Transparent"
                ColumnSpacing="8"
                IsHitTestVisible="True"
                PointerPressed="ThumbnailAndTitlesGrid_PointerPressed"
                Visibility="{x:Bind ViewModel.ShowTitleArtistAndThumbnail, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Album art thumbnail  -->
                <Grid
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
                    <Image
                        x:Name="ThumbnailImage"
                        Source="{x:Bind ViewModel.Thumbnail, Mode=OneWay}"
                        Stretch="Uniform" />
                </Grid>

                <!--  Marquee (compact mode only)  -->
                <controls:Marquee
                    x:Name="MarqueeText"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    MinHeight="16"
                    VerticalAlignment="Center"
                    Behavior="Looping"
                    Content="{x:Bind ViewModel.SongAndArtistName, Mode=OneWay}"
                    Direction="Left"
                    FontSize="{ThemeResource SillFontSize}"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Loaded="MarqueeText_Loaded"
                    RepeatBehavior="Forever"
                    Speed="25"
                    Visibility="Collapsed" />

                <!--  Song name  -->
                <TextBlock
                    x:Name="SongTextBlock"
                    Grid.Row="0"
                    Grid.RowSpan="{x:Bind ViewModel.HasArtistName, Mode=OneWay, Converter={StaticResource ArtistRowSpanConverter}}"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    FontSize="16"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="{x:Bind ViewModel.SongName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <!--  Artist name  -->
                <TextBlock
                    x:Name="ArtistTextBlock"
                    Grid.Row="1"
                    Grid.Column="1"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="SemiLight"
                    Opacity="0.5"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

            </Grid>

            <!--  Playback controls  -->
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.PreviousCommand}"
                    IsEnabled="{x:Bind ViewModel.IsPreviousAvailable, Mode=OneWay}"
                    Style="{StaticResource IconButton}">
                    <Path
                        Width="{ThemeResource SillFontIconSize}"
                        Height="{ThemeResource SillFontIconSize}"
                        Data="F1 M 3 5.279999 C 3 5.146667 3.046667 5.033333 3.14 4.940001 C 3.233333 4.846666 3.353333 4.799999 3.5 4.799999 C 3.646667 4.799999 3.766666 4.846666 3.86 4.940001 C 3.953333 5.033333 4 5.146667 4 5.279999 L 4 18.279999 C 4 18.439999 3.953333 18.566666 3.86 18.66 C 3.766666 18.753332 3.646667 18.799999 3.5 18.799999 C 3.353333 18.799999 3.233333 18.753332 3.14 18.66 C 3.046667 18.566666 3 18.439999 3 18.279999 Z M 17 6.04 C 17 5.720001 16.893333 5.446667 16.68 5.219999 C 16.466665 4.993332 16.206665 4.860001 15.9 4.82 C 15.593332 4.780001 15.306665 4.84 15.04 5 L 6.56 10.719999 C 6.186666 10.96 6 11.3 6 11.74 C 6 12.18 6.186666 12.533333 6.56 12.799999 L 15.04 18.599998 C 15.226665 18.733334 15.439999 18.799999 15.679999 18.799999 C 15.919998 18.799999 16.139999 18.746666 16.34 18.639999 C 16.539999 18.533333 16.699999 18.379999 16.82 18.18 C 16.939999 17.98 17 17.773333 17 17.559999 Z M 15.599999 5.839999 C 15.679998 5.786667 15.766665 5.786667 15.86 5.839999 C 15.953333 5.893333 16 5.96 16 6.04 L 16 17.559999 C 16 17.666666 15.953333 17.74 15.86 17.779999 C 15.766665 17.82 15.679998 17.813334 15.599999 17.759998 L 7.12 11.959999 C 7.04 11.906666 7 11.839999 7 11.759999 C 7 11.68 7.04 11.613333 7.12 11.559999 Z "
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Stretch="Uniform" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.PlayPauseCommand}"
                    IsEnabled="{x:Bind ViewModel.IsPlayPauseAvailable, Mode=OneWay}"
                    Style="{StaticResource IconButton}">
                    <Path
                        Width="{ThemeResource SillFontIconSize}"
                        Height="{ThemeResource SillFontIconSize}"
                        Data="{x:Bind ViewModel.IsPlaying, Mode=OneWay, Converter={StaticResource IsPlayingToGlyphConverter}}"
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Stretch="Uniform" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.NextCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNextAvailable, Mode=OneWay}"
                    Style="{StaticResource IconButton}">
                    <Path
                        Width="{ThemeResource SillFontIconSize}"
                        Height="{ThemeResource SillFontIconSize}"
                        Data="F1 M 17 5.279999 C 17 5.146667 16.953333 5.033333 16.859999 4.940001 C 16.766666 4.846666 16.646666 4.799999 16.5 4.799999 C 16.353333 4.799999 16.233332 4.846666 16.139999 4.940001 C 16.046665 5.033333 16 5.146667 16 5.279999 L 16 18.279999 C 16 18.439999 16.046665 18.566666 16.139999 18.66 C 16.233332 18.753332 16.353333 18.799999 16.5 18.799999 C 16.646666 18.799999 16.766666 18.753332 16.859999 18.66 C 16.953333 18.566666 17 18.439999 17 18.279999 Z M 3 6.04 C 3 5.720001 3.106667 5.446667 3.32 5.219999 C 3.533333 4.993332 3.793333 4.860001 4.1 4.82 C 4.406666 4.780001 4.693333 4.84 4.96 5 L 13.44 10.719999 C 13.813334 10.96 14 11.3 14 11.74 C 14 12.18 13.813334 12.533333 13.44 12.799999 L 4.96 18.599998 C 4.773333 18.733334 4.559999 18.799999 4.32 18.799999 C 4.079999 18.799999 3.86 18.746666 3.66 18.639999 C 3.46 18.533333 3.3 18.379999 3.18 18.18 C 3.06 17.98 3 17.773333 3 17.559999 Z M 4.4 5.839999 C 4.32 5.786667 4.233333 5.786667 4.14 5.839999 C 4.046667 5.893333 4 5.96 4 6.04 L 4 17.559999 C 4 17.666666 4.046667 17.74 4.14 17.779999 C 4.233333 17.82 4.32 17.813334 4.4 17.759998 L 12.88 11.959999 C 12.959999 11.906666 13 11.839999 13 11.759999 C 13 11.68 12.959999 11.613333 12.88 11.559999 Z "
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Stretch="Uniform" />
                </Button>
            </StackPanel>

        </api:SillOrientedStackPanel>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SillOrientationStates">

                <!--  Default state: HorizontalLarge  -->
                <VisualState x:Name="HorizontalLarge">
                    <VisualState.Setters>
                        <Setter Target="MarqueeText.Visibility" Value="Collapsed" />
                        <Setter Target="SongTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ThumbnailImage.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.FontSize" Value="12" />
                        <Setter Target="SongTextBlock.FontSize" Value="16" />
                        <Setter Target="ThumbnailAndTitlesGrid.Width" Value="190" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HorizontalMedium">
                    <VisualState.Setters>
                        <Setter Target="MarqueeText.Visibility" Value="Collapsed" />
                        <Setter Target="SongTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ThumbnailImage.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.FontSize" Value="10" />
                        <Setter Target="SongTextBlock.FontSize" Value="10" />
                        <Setter Target="ThumbnailAndTitlesGrid.Width" Value="160" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HorizontalSmall">
                    <VisualState.Setters>
                        <Setter Target="MarqueeText.Visibility" Value="Visible" />
                        <Setter Target="SongTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="ArtistTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="ThumbnailImage.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.FontSize" Value="12" />
                        <Setter Target="SongTextBlock.FontSize" Value="{ThemeResource SillFontSize}" />
                        <Setter Target="ThumbnailAndTitlesGrid.Width" Value="140" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalLarge">
                    <VisualState.Setters>
                        <Setter Target="MarqueeText.Visibility" Value="Collapsed" />
                        <Setter Target="SongTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ThumbnailImage.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.FontSize" Value="12" />
                        <Setter Target="SongTextBlock.FontSize" Value="16" />
                        <Setter Target="ThumbnailAndTitlesGrid.Width" Value="NaN" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalMedium">
                    <VisualState.Setters>
                        <Setter Target="MarqueeText.Visibility" Value="Collapsed" />
                        <Setter Target="SongTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ThumbnailImage.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.FontSize" Value="12" />
                        <Setter Target="SongTextBlock.FontSize" Value="{ThemeResource SillFontSize}" />
                        <Setter Target="ThumbnailAndTitlesGrid.Width" Value="NaN" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalSmall">
                    <VisualState.Setters>
                        <Setter Target="MarqueeText.Visibility" Value="Collapsed" />
                        <Setter Target="SongTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ArtistTextBlock.Visibility" Value="Visible" />
                        <Setter Target="ThumbnailImage.Visibility" Value="Collapsed" />
                        <Setter Target="ArtistTextBlock.FontSize" Value="12" />
                        <Setter Target="SongTextBlock.FontSize" Value="{ThemeResource SillFontSize}" />
                        <Setter Target="ThumbnailAndTitlesGrid.Width" Value="NaN" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>

</UserControl>
