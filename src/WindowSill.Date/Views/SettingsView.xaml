<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:conv="using:WindowSill.Date.Core.UI.Converters"
    xmlns:converters1="using:CommunityToolkit.WinUI.Converters"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WindowSill.Date.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:WindowSill.Date.ViewModels"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters1:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:HexColorBrushConverter x:Key="HexColorBrushConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="0,0,0,16" Spacing="16">

            <!--  Accounts section  -->
            <StackPanel Spacing="8">
                <TextBlock api:Uids.Uid="/WindowSill.Date/Settings/AccountsSectionHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />

                <!--  Add account button  -->
                <DropDownButton>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                        <TextBlock api:Uids.Uid="/WindowSill.Date/Settings/AddAccount" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="AddAccountMenuFlyout" Placement="Bottom" />
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!--  Empty state  -->
                <TextBlock
                    api:Uids.Uid="/WindowSill.Date/Settings/NoAccountsMessage"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.HasNoAccounts, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

                <!--  Account list as SettingsExpanders  -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Accounts}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="2" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:AccountViewModel">
                            <ctk:SettingsExpander
                                Description="{x:Bind Email}"
                                Header="{x:Bind DisplayName}"
                                ItemsSource="{x:Bind Calendars}">
                                <ctk:SettingsExpander.HeaderIcon>
                                    <ImageIcon Source="{x:Bind ProviderIconSource}" />
                                </ctk:SettingsExpander.HeaderIcon>
                                <ctk:SettingsExpander.ItemsHeader>
                                    <InfoBar
                                        HorizontalAlignment="Stretch"
                                        api:Uids.Uid="/WindowSill.Date/Settings/LoadingCalendars"
                                        BorderThickness="0"
                                        CornerRadius="0"
                                        IsClosable="False"
                                        IsIconVisible="False"
                                        IsOpen="{x:Bind IsLoadingCalendars, Mode=OneWay}"
                                        Severity="Informational" />
                                </ctk:SettingsExpander.ItemsHeader>
                                <Button
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    api:Uids.Uid="/WindowSill.Date/Settings/RemoveAccount"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Command="{x:Bind RemoveCommand}"
                                    Content="{ui:FontIcon FontFamily={StaticResource SegoeFluentIcons},
                                                          Glyph=&#xE74D;,
                                                          FontSize=16}" />
                                <ctk:SettingsExpander.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CalendarViewModel">
                                        <ctk:SettingsCard Header="{x:Bind Name}">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    api:Uids.Uid="/WindowSill.Date/Settings/CalendarColor"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Click="CalendarColorButton_Click"
                                                    DataContext="{x:Bind}">
                                                    <Ellipse
                                                        Width="16"
                                                        Height="16"
                                                        Fill="{x:Bind Color, Mode=OneWay, Converter={StaticResource HexColorBrushConverter}}" />
                                                </Button>
                                                <CheckBox IsChecked="{x:Bind IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </ctk:SettingsCard>
                                    </DataTemplate>
                                </ctk:SettingsExpander.ItemTemplate>
                            </ctk:SettingsExpander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!--  Future settings sections go here  -->

            <!--  General section  -->
            <StackPanel Spacing="2">
                <TextBlock
                    Margin="0,8,0,8"
                    api:Uids.Uid="/WindowSill.Date/Display/GeneralSectionHeader"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />

                <!--  Sill content mode  -->
                <ctk:SettingsExpander api:Uids.Uid="/WindowSill.Date/Display/DisplayMode">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE787;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ComboBox
                        Width="180"
                        ItemsSource="{x:Bind ViewModel.AvailableDisplayModes}"
                        SelectedItem="{x:Bind ViewModel.SelectedDisplayMode, Mode=TwoWay}" />

                    <ctk:SettingsExpander.Items>
                        <!--  Icon mode info  -->
                        <ctk:SettingsCard Visibility="{x:Bind ViewModel.IsIconModeInfoVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ctk:SettingsCard.Header>
                                <TextBlock
                                    api:Uids.Uid="/WindowSill.Date/Display/IconModeInfo"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}" />
                            </ctk:SettingsCard.Header>
                        </ctk:SettingsCard>

                        <!--  Date format  -->
                        <ctk:SettingsCard
                            x:Name="DateFormatCard"
                            api:Uids.Uid="/WindowSill.Date/Display/DateFormat"
                            Visibility="{x:Bind ViewModel.IsDateTimeMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ComboBox
                                Width="220"
                                ItemsSource="{x:Bind ViewModel.AvailableDateFormats, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedDateFormat, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <!--  Time format  -->
                        <ctk:SettingsCard
                            x:Name="TimeFormatCard"
                            api:Uids.Uid="/WindowSill.Date/Display/TimeFormat"
                            Visibility="{x:Bind ViewModel.IsDateTimeMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ComboBox
                                Width="180"
                                ItemsSource="{x:Bind ViewModel.AvailableTimeFormats, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedTimeFormat, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <!--  Show seconds  -->
                        <ctk:SettingsCard
                            x:Name="ShowSecondsCard"
                            api:Uids.Uid="/WindowSill.Date/Display/ShowSeconds"
                            Visibility="{x:Bind ViewModel.IsShowSecondsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.ShowSeconds, Mode=TwoWay}" />
                        </ctk:SettingsCard>
                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!--  Show past events  -->
                <ctk:SettingsCard api:Uids.Uid="/WindowSill.Date/Display/ShowPastEvents">
                    <ctk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE81C;" />
                    </ctk:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ShowPastEvents, Mode=TwoWay}" />
                </ctk:SettingsCard>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
