<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:converters1="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WindowSill.Date.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WindowSill.Date.ViewModels"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters1:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters1:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="0,0,0,16" Spacing="16">

            <!--  Accounts section  -->
            <StackPanel Spacing="8">
                <TextBlock api:Uids.Uid="/WindowSill.Date/Settings/AccountsSectionHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />

                <!--  Add account button  -->
                <DropDownButton IsEnabled="{x:Bind ViewModel.IsAddingAccount, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                        <TextBlock api:Uids.Uid="/WindowSill.Date/Settings/AddAccount" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem api:Uids.Uid="/WindowSill.Date/Settings/AddOutlook" Click="AddOutlookMenuItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <ImageIcon Source="{x:Bind ViewModel.OutlookIconSource}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem api:Uids.Uid="/WindowSill.Date/Settings/AddGoogle" Click="AddGoogleMenuItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <ImageIcon Source="{x:Bind ViewModel.GoogleIconSource}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem api:Uids.Uid="/WindowSill.Date/Settings/AddICloud" Click="AddICloudMenuItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <ImageIcon Source="{x:Bind ViewModel.ICloudIconSource}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem api:Uids.Uid="/WindowSill.Date/Settings/AddCalDav" Click="AddCalDavMenuItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <ImageIcon Source="{x:Bind ViewModel.CalDavIconSource}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!--  Empty state  -->
                <TextBlock
                    api:Uids.Uid="/WindowSill.Date/Settings/NoAccountsMessage"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.HasNoAccounts, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

                <!--  Account list  -->
                <ListView ItemsSource="{x:Bind ViewModel.Accounts}" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Padding" Value="0,2,0,0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:AccountViewModel">
                            <Border
                                Height="48"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource ControlCornerRadius}">
                                <Grid Padding="12,0" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Source="{x:Bind ProviderIconSource}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Email}"
                                        TextTrimming="CharacterEllipsis" />

                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind ProviderLabel}" />

                                    <Button
                                        Grid.Column="3"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        api:Uids.Uid="/WindowSill.Date/Settings/RemoveAccount"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Click="RemoveAccountButton_Click">
                                        <FontIcon
                                            FontFamily="{StaticResource SegoeFluentIcons}"
                                            FontSize="12"
                                            Glyph="&#xE711;" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!--  Future settings sections go here  -->

        </StackPanel>
    </ScrollViewer>
</UserControl>
