<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.MeetingPreviewFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel MaxWidth="300" Spacing="4">
        <!--  Full meeting title (no truncation)  -->
        <TextBlock
            FontWeight="SemiBold"
            Text="{x:Bind ViewModel.Title}"
            TextWrapping="Wrap" />

        <!--  Countdown: "in 22 minutes" (live-updating)  -->
        <TextBlock
            Foreground="{ThemeResource SystemAccentColorLight2}"
            Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />

        <!--  Exact date/time: "Saturday, April 18, 2026 at 9:30 PM"  -->
        <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Text="{x:Bind ViewModel.FullDateTimeText}"
            TextWrapping="Wrap" />
    </StackPanel>

</UserControl>
