<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.MeetingPreviewFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel MaxWidth="300" Spacing="4">
        <!--  Full meeting title (no truncation)  -->
        <TextBlock
            x:Name="TitleText"
            FontWeight="SemiBold"
            TextWrapping="Wrap" />

        <!--  Countdown: "in 22 minutes"  -->
        <TextBlock
            x:Name="CountdownText"
            Foreground="{ThemeResource SystemAccentColorLight2}" />

        <!--  Exact date/time: "Saturday, April 18, 2026 at 9:30 PM"  -->
        <TextBlock
            x:Name="DateTimeText"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            TextWrapping="Wrap" />
    </StackPanel>

</UserControl>
