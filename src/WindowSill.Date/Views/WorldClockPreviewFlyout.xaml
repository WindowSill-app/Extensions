<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.WorldClockPreviewFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:WindowSill.Date.Core.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:DayNightGlyphConverter x:Key="DayNightGlyphConverter" />
    </UserControl.Resources>

    <StackPanel
        MaxWidth="240"
        Padding="8"
        Spacing="4">

        <!--  Day/night icon + city name  -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon
                VerticalAlignment="Center"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                FontSize="14"
                Glyph="{x:Bind ViewModel.IsDaytime, Mode=OneWay, Converter={StaticResource DayNightGlyphConverter}}" />
            <TextBlock
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.DisplayName}" />
        </StackPanel>

        <!--  Current time (large)  -->
        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Text="{x:Bind ViewModel.CurrentTime, Mode=OneWay}"
            Typography.NumeralAlignment="Tabular" />

        <!--  Current date  -->
        <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Text="{x:Bind ViewModel.CurrentDate, Mode=OneWay}" />

        <!--  UTC offset  -->
        <TextBlock
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Text="{x:Bind ViewModel.OffsetText, Mode=OneWay}" />
    </StackPanel>

</UserControl>
