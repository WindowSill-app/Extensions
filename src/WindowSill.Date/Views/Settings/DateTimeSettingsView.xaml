<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.DateTimeSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:converters1="using:CommunityToolkit.WinUI.Converters"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters1:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="0,0,0,16" Spacing="16">

            <!--  Sill display  -->
            <StackPanel Spacing="2">
                <TextBlock
                    Margin="0,0,0,8"
                    api:Uids.Uid="/WindowSill.Date/Display/SillDisplayHeader"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />

                <ctk:SettingsExpander api:Uids.Uid="/WindowSill.Date/Display/DisplayMode">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE787;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ComboBox
                        Width="180"
                        ItemsSource="{x:Bind ViewModel.AvailableDisplayModes}"
                        SelectedItem="{x:Bind ViewModel.SelectedDisplayMode, Mode=TwoWay}" />

                    <ctk:SettingsExpander.Items>
                        <!--  Icon mode info  -->
                        <ctk:SettingsCard Visibility="{x:Bind ViewModel.IsIconModeInfoVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ctk:SettingsCard.Header>
                                <TextBlock
                                    api:Uids.Uid="/WindowSill.Date/Display/IconModeInfo"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}" />
                            </ctk:SettingsCard.Header>
                        </ctk:SettingsCard>

                        <!--  Date format  -->
                        <ctk:SettingsCard api:Uids.Uid="/WindowSill.Date/Display/DateFormat" Visibility="{x:Bind ViewModel.IsDateTimeMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ComboBox
                                Width="220"
                                ItemsSource="{x:Bind ViewModel.AvailableDateFormats, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedDateFormat, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <!--  Time format  -->
                        <ctk:SettingsCard api:Uids.Uid="/WindowSill.Date/Display/TimeFormat" Visibility="{x:Bind ViewModel.IsDateTimeMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ComboBox
                                Width="180"
                                ItemsSource="{x:Bind ViewModel.AvailableTimeFormats, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedTimeFormat, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <!--  Show seconds  -->
                        <ctk:SettingsCard api:Uids.Uid="/WindowSill.Date/Display/ShowSeconds" Visibility="{x:Bind ViewModel.IsShowSecondsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.ShowSeconds, Mode=TwoWay}" />
                        </ctk:SettingsCard>
                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>
            </StackPanel>

            <!--  Popup  -->
            <StackPanel Spacing="2">
                <TextBlock
                    Margin="0,0,0,8"
                    api:Uids.Uid="/WindowSill.Date/Display/PopupHeader"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />

                <!--  Show past events  -->
                <ctk:SettingsCard api:Uids.Uid="/WindowSill.Date/Display/ShowPastEvents">
                    <ctk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE81C;" />
                    </ctk:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ShowPastEvents, Mode=TwoWay}" />
                </ctk:SettingsCard>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
