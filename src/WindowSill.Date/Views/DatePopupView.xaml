<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.Date.Views.DatePopupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:conv="using:WindowSill.Date.Core.UI.Converters"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WindowSill.Date.ViewModels"
    Width="320"
    mc:Ignorable="d">

    <api:SillPopupContent.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter
            x:Key="InverseBoolToVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
        <conv:HexColorBrushConverter x:Key="HexColorBrushConverter" />
        <conv:PastOpacityConverter x:Key="PastOpacityConverter" />
        <conv:NowFontWeightConverter x:Key="NowFontWeightConverter" />
        <conv:DayNightGlyphConverter x:Key="DayNightGlyphConverter" />
    </api:SillPopupContent.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CalendarView
            x:Name="CalendarControl"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            CalendarViewDayItemChanging="CalendarControl_DayItemChanging"
            CornerRadius="0"
            IsTodayHighlighted="True"
            SelectedDatesChanged="CalendarControl_SelectedDatesChanged"
            SelectionMode="Single" />

        <Grid Grid.Row="1" MinHeight="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Event list header  -->
            <TextBlock
                Grid.Row="0"
                Margin="16,8,16,4"
                FontWeight="SemiBold"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="{x:Bind ViewModel.EventListHeader, Mode=OneWay}" />

            <!--  Loading indicator  -->
            <ProgressBar
                Grid.Row="0"
                VerticalAlignment="Bottom"
                IsIndeterminate="True"
                Visibility="{x:Bind ViewModel.IsLoadingEvents, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Event list  -->
            <ListView
                x:Name="EventListView"
                Grid.Row="1"
                Padding="4,0"
                ItemsSource="{x:Bind ViewModel.Events}"
                SelectionMode="None"
                Visibility="{x:Bind ViewModel.HasNoEvents, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EventItemViewModel">
                        <Grid
                            Padding="12,6"
                            Background="Transparent"
                            ColumnSpacing="8"
                            Opacity="{x:Bind IsPast, Converter={StaticResource PastOpacityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Calendar color indicator  -->
                            <Ellipse
                                Grid.Column="0"
                                Width="8"
                                Height="8"
                                VerticalAlignment="Center"
                                Fill="{x:Bind Color, Converter={StaticResource HexColorBrushConverter}}" />

                            <!--  Title and time  -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock
                                    FontWeight="{x:Bind IsNow, Converter={StaticResource NowFontWeightConverter}}"
                                    Text="{x:Bind Title}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Text="{x:Bind TimeRangeText}" />
                            </StackPanel>

                            <!--  Video call indicator  -->
                            <FontIcon
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="14"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE714;"
                                Visibility="{x:Bind HasVideoCall, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!--  Context menu  -->
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        api:Uids.Uid="/WindowSill.Date/Popup/JoinMeeting"
                                        Click="JoinMeeting_Click"
                                        DataContext="{x:Bind}"
                                        Visibility="{x:Bind HasVideoCall, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE714;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        api:Uids.Uid="/WindowSill.Date/Popup/OpenInCalendar"
                                        Click="OpenInCalendar_Click"
                                        DataContext="{x:Bind}"
                                        Visibility="{x:Bind HasWebLink, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A7;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  Empty state  -->
            <TextBlock
                Grid.Row="1"
                Margin="16,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                api:Uids.Uid="/WindowSill.Date/Popup/NoEvents"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Visibility="{x:Bind ViewModel.HasNoEvents, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <StackPanel
            Grid.Row="2"
            Padding="16,8,16,12"
            BorderBrush="{ThemeResource CalendarViewBorderBrush}"
            BorderThickness="0,1,0,0"
            Spacing="4"
            Visibility="{x:Bind ViewModel.HasWorldClocks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

            <!--  World Clocks header  -->
            <TextBlock
                Margin="0,0,0,2"
                api:Uids.Uid="/WindowSill.Date/Popup/WorldClocksHeader"
                FontWeight="SemiBold"
                Style="{ThemeResource BodyStrongTextBlockStyle}" />

            <!--  Clock list  -->
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.WorldClocks}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:WorldClockItemViewModel">
                        <Grid Padding="0,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Day/night indicator  -->
                            <FontIcon
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="14"
                                Glyph="{x:Bind IsDaytime, Mode=OneWay, Converter={StaticResource DayNightGlyphConverter}}" />

                            <!--  Name and offset  -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Text="{x:Bind OffsetText, Mode=OneWay}" />
                            </StackPanel>

                            <!--  Time and day  -->
                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind CurrentTime, Mode=OneWay}"
                                    Typography.NumeralAlignment="Tabular" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Text="{x:Bind DayText, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!--  Time travel info + slider  -->
            <StackPanel Margin="0,6,0,0" Spacing="4">

                <Grid
                    Padding="10,8"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Offset badge  -->
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,2"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.TimeTravelLabel, Mode=OneWay}"
                        Typography.NumeralAlignment="Tabular" />

                    <!--  Projected time + relative day  -->
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.TimeTravelProjectedTime, Mode=OneWay}"
                            Typography.NumeralAlignment="Tabular" />
                        <TextBlock
                            VerticalAlignment="Bottom"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.TimeTravelProjectedDay, Mode=OneWay}" />
                    </StackPanel>

                    <!--  Projected date  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.TimeTravelProjectedDate, Mode=OneWay}" />
                </Grid>

                <Slider
                    x:Name="TimeTravelSlider"
                    IsThumbToolTipEnabled="False"
                    Maximum="1440"
                    Minimum="-1440"
                    SnapsTo="StepValues"
                    StepFrequency="60"
                    Value="{x:Bind ViewModel.TimeTravelOffsetMinutes, Mode=TwoWay}" />
            </StackPanel>
        </StackPanel>
    </Grid>

</api:SillPopupContent>
