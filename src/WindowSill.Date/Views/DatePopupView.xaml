<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.Date.Views.DatePopupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:controls="using:WindowSill.Date.Core.UI.Controls"
    xmlns:conv="using:WindowSill.Date.Core.UI.Converters"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WindowSill.Date.ViewModels"
    Width="320"
    mc:Ignorable="d">

    <api:SillPopupContent.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter
            x:Key="InverseBoolToVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
        <conv:HexColorBrushConverter x:Key="HexColorBrushConverter" />
        <conv:PastOpacityConverter x:Key="PastOpacityConverter" />
        <conv:NowFontWeightConverter x:Key="NowFontWeightConverter" />
        <conv:DayNightGlyphConverter x:Key="DayNightGlyphConverter" />
    </api:SillPopupContent.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            BorderBrush="{ThemeResource CalendarViewBorderBrush}"
            BorderThickness="0,0,0,1">
            <Button
                Padding="16,6"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Click="ToggleCalendar_Click"
                CornerRadius="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        api:Uids.Uid="/WindowSill.Date/Popup/CalendarHeader"
                        FontWeight="SemiBold"
                        Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <FontIcon
                        x:Name="CalendarChevron"
                        Grid.Column="1"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE70E;" />
                </Grid>
            </Button>
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <CalendarView
                    x:Name="CalendarControl"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    CalendarViewDayItemChanging="CalendarControl_DayItemChanging"
                    CornerRadius="0"
                    IsTodayHighlighted="True"
                    SelectedDatesChanged="CalendarControl_SelectedDatesChanged"
                    SelectionMode="Single"
                    Visibility="{x:Bind ViewModel.IsCalendarVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" MinHeight="90">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Event list header  -->
            <TextBlock
                Grid.Row="0"
                Margin="16,8,16,4"
                FontWeight="SemiBold"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="{x:Bind ViewModel.EventListHeader, Mode=OneWay}" />

            <!--  Loading indicator  -->
            <ProgressBar
                Grid.Row="0"
                VerticalAlignment="Bottom"
                IsIndeterminate="True"
                Visibility="{x:Bind ViewModel.IsLoadingEvents, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Event list  -->
            <ScrollView
                Grid.Row="1"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollChainMode="Never"
                HorizontalScrollMode="Disabled"
                Visibility="{x:Bind ViewModel.HasNoEvents, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ItemsControl x:Name="EventListView" ItemsSource="{x:Bind ViewModel.Events}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EventItemViewModel">
                            <Border Opacity="{x:Bind IsPast, Converter={StaticResource PastOpacityConverter}}">
                                <Grid Padding="16,8,16,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Calendar color vertical bar  -->
                                    <!--  Solid bar (accepted)  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="6"
                                        VerticalAlignment="Stretch"
                                        Background="{x:Bind Color, Converter={StaticResource HexColorBrushConverter}}"
                                        CornerRadius="2"
                                        Visibility="{x:Bind IsTentative, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <!--  Zebra-striped bar (tentative / not responded)  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="6"
                                        VerticalAlignment="Stretch"
                                        BorderBrush="{x:Bind Color, Converter={StaticResource HexColorBrushConverter}}"
                                        BorderThickness="2"
                                        CornerRadius="2"
                                        Visibility="{x:Bind IsTentative, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <controls:DiagonalStripePanel StrokeBrush="{x:Bind Color, Converter={StaticResource HexColorBrushConverter}}" />
                                    </Border>

                                    <!--  Title and time  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontWeight="{x:Bind IsNow, Converter={StaticResource NowFontWeightConverter}}"
                                            Text="{x:Bind Title}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{x:Bind TimeRangeText}" />
                                    </StackPanel>

                                    <!--  Video call indicator  -->
                                    <FontIcon
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE714;"
                                        Visibility="{x:Bind HasVideoCall, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <!--  Context menu  -->
                                    <Grid.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                api:Uids.Uid="/WindowSill.Date/Popup/JoinMeeting"
                                                Click="JoinMeeting_Click"
                                                DataContext="{x:Bind}"
                                                Visibility="{x:Bind HasVideoCall, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE714;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem
                                                api:Uids.Uid="/WindowSill.Date/Popup/OpenInCalendar"
                                                Click="OpenInCalendar_Click"
                                                DataContext="{x:Bind}"
                                                Visibility="{x:Bind HasWebLink, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE8A7;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollView>

            <!--  Empty state  -->
            <TextBlock
                Grid.Row="1"
                Margin="16,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                api:Uids.Uid="/WindowSill.Date/Popup/NoEvents"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Visibility="{x:Bind ViewModel.HasNoEvents, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <StackPanel
            Grid.Row="2"
            BorderBrush="{ThemeResource CalendarViewBorderBrush}"
            BorderThickness="0,1,0,0"
            Spacing="0"
            Visibility="{x:Bind ViewModel.HasWorldClocks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Padding="16,6"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Click="ToggleWorldClocks_Click"
                CornerRadius="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        api:Uids.Uid="/WindowSill.Date/Popup/WorldClocksHeader"
                        FontWeight="SemiBold"
                        Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <FontIcon
                        x:Name="WorldClocksChevron"
                        Grid.Column="1"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE70E;" />
                </Grid>
            </Button>

            <StackPanel
                Padding="16,0,16,4"
                Spacing="4"
                Visibility="{x:Bind ViewModel.IsWorldClocksVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                <!--  Clock list  -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.WorldClocks}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="2" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorldClockItemViewModel">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Day/night indicator  -->
                                <FontIcon
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="14"
                                    Glyph="{x:Bind IsDaytime, Mode=OneWay, Converter={StaticResource DayNightGlyphConverter}}" />

                                <!--  Name and offset  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{x:Bind OffsetText, Mode=OneWay}" />
                                </StackPanel>

                                <!--  Time and day  -->
                                <StackPanel
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind CurrentTime, Mode=OneWay}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{x:Bind DayText, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!--  Time travel card (slider + info unified)  -->
                <Grid
                    Margin="0,6,0,0"
                    Padding="0,8,0,8"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    RowSpacing="2">
                    <Grid.RowDefinitions>
                        <!--  Header: label + offset  -->
                        <RowDefinition Height="Auto" />
                        <!--  Slider  -->
                        <RowDefinition Height="Auto" />
                        <!--  Projected time (only when traveling)  -->
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Row 0: "Time travel" label + offset badge  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6">
                            <FontIcon
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE81C;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                api:Uids.Uid="/WindowSill.Date/Popup/TimeTravelLabel"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.TimeTravelLabel, Mode=OneWay}"
                            Typography.NumeralAlignment="Tabular" />
                    </Grid>

                    <!--  Row 1: Slider  -->
                    <Slider
                        x:Name="TimeTravelSlider"
                        Grid.Row="1"
                        Margin="-4,0"
                        IsThumbToolTipEnabled="False"
                        Maximum="1440"
                        Minimum="-1440"
                        SnapsTo="StepValues"
                        StepFrequency="60"
                        Value="{x:Bind ViewModel.TimeTravelOffsetMinutes, Mode=TwoWay}" />

                    <!--  Row 2: Projected time details (visible when offset != 0)  -->
                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!--  Projected time + relative day  -->
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.TimeTravelProjectedTime, Mode=OneWay}"
                                Typography.NumeralAlignment="Tabular" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.TimeTravelProjectedDay, Mode=OneWay}" />
                        </StackPanel>
                        <!--  Projected date  -->
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind ViewModel.TimeTravelProjectedDate, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>

</api:SillPopupContent>
