<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.Views.MeetingBarContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WindowSill.Date.Core.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:converters1="using:WindowSill.Date.Core.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WindowSill.Date.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter
            x:Key="InverseBoolToVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
        <converters1:HexColorBrushConverter x:Key="HexColorBrushConverter" />
        <converters1:UrgentFontWeightConverter x:Key="UrgentFontWeightConverter" />
    </UserControl.Resources>

    <Grid
        x:Name="RootPanel"
        Margin="4,0,0,0"
        VerticalAlignment="Stretch"
        ColumnSpacing="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid VerticalAlignment="Center" ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  Calendar color vertical bar  -->
            <!--  Solid bar (accepted)  -->
            <Border
                Grid.Column="0"
                Width="6"
                VerticalAlignment="Stretch"
                Background="{x:Bind ViewModel.CalendarColor, Mode=OneWay, Converter={StaticResource HexColorBrushConverter}}"
                CornerRadius="2"
                Visibility="{x:Bind ViewModel.IsTentative, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
            <!--  Zebra-striped bar (tentative / not responded)  -->
            <Border
                Grid.Column="0"
                Width="6"
                Margin="0,4"
                VerticalAlignment="Stretch"
                BorderBrush="{x:Bind ViewModel.CalendarColor, Mode=OneWay, Converter={StaticResource HexColorBrushConverter}}"
                BorderThickness="2"
                CornerRadius="2"
                Visibility="{x:Bind ViewModel.IsTentative, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DiagonalStripePanel StrokeBrush="{x:Bind ViewModel.CalendarColor, Converter={StaticResource HexColorBrushConverter}}" />
            </Border>

            <!--  Single-line layout (Medium/Small)  -->
            <Grid
                x:Name="SingleLinePanel"
                Grid.Column="1"
                VerticalAlignment="Center"
                ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="TitleTextSingle"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="{ThemeResource SillFontSize}"
                    Text="{x:Bind ViewModel.Title}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <TextBlock
                    x:Name="CountdownTextSingle"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="{ThemeResource SillFontSize}"
                    FontWeight="{x:Bind ViewModel.IsUrgent, Mode=OneWay, Converter={StaticResource UrgentFontWeightConverter}}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}"
                    Typography.NumeralAlignment="Tabular" />
            </Grid>

            <!--  Two-line layout (Large) — hidden by default, shown via VisualState  -->
            <StackPanel
                x:Name="TwoLinePanel"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="0"
                Visibility="Collapsed">

                <TextBlock
                    x:Name="TitleTextLarge"
                    HorizontalAlignment="Left"
                    FontSize="{ThemeResource SillFontSize}"
                    Text="{x:Bind ViewModel.Title}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <StackPanel
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Spacing="6">

                    <TextBlock
                        x:Name="CountdownTextLarge"
                        VerticalAlignment="Center"
                        FontSize="{ThemeResource SillFontSize}"
                        FontWeight="{x:Bind ViewModel.IsUrgent, Mode=OneWay, Converter={StaticResource UrgentFontWeightConverter}}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}"
                        Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Button
            x:Name="JoinButtonSingle"
            Grid.Column="2"
            MaxWidth="24"
            Click="JoinButton_Click"
            Content="&#xE714;"
            Style="{StaticResource IconButton}"
            Visibility="{x:Bind ViewModel.IsJoinVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="OrientationStates">

                <!--  Large: two-line layout (title above, countdown below)  -->
                <VisualState x:Name="HorizontalLarge">
                    <VisualState.Setters>
                        <Setter Target="SingleLinePanel.Visibility" Value="Collapsed" />
                        <Setter Target="TwoLinePanel.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <!--  Medium: single-line (default)  -->
                <VisualState x:Name="HorizontalMedium" />

                <!--  Small: single-line, compact  -->
                <VisualState x:Name="HorizontalSmall">
                    <VisualState.Setters>
                        <Setter Target="SingleLinePanel.ColumnSpacing" Value="4" />
                    </VisualState.Setters>
                </VisualState>

                <!--  Vertical Large: two-line  -->
                <VisualState x:Name="VerticalLarge">
                    <VisualState.Setters>
                        <Setter Target="SingleLinePanel.Visibility" Value="Collapsed" />
                        <Setter Target="TwoLinePanel.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <!--  Vertical Medium: single-line  -->
                <VisualState x:Name="VerticalMedium" />

                <!--  Vertical Small: single-line, compact  -->
                <VisualState x:Name="VerticalSmall">
                    <VisualState.Setters>
                        <Setter Target="RootPanel.Margin" Value="0" />
                        <Setter Target="SingleLinePanel.ColumnSpacing" Value="4" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>

</UserControl>
