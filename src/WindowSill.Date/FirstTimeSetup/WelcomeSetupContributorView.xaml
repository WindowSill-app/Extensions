<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.Date.FirstTimeSetup.WelcomeSetupContributorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="12">
        <TextBlock api:Uids.Uid="/WindowSill.Date/FirstTimeSetup/WelcomeDescription" TextWrapping="WrapWholeWords" />

        <StackPanel Margin="0,8,0,0" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon FontSize="16" Glyph="&#xE787;" />
                <TextBlock api:Uids.Uid="/WindowSill.Date/FirstTimeSetup/FeatureCalendar" TextWrapping="WrapWholeWords" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon FontSize="16" Glyph="&#xE8D1;" />
                <TextBlock api:Uids.Uid="/WindowSill.Date/FirstTimeSetup/FeatureMeetings" TextWrapping="WrapWholeWords" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon FontSize="16" Glyph="&#xE81C;" />
                <TextBlock api:Uids.Uid="/WindowSill.Date/FirstTimeSetup/FeatureWorldClocks" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
