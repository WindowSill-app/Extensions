    <value>The Date feature keeps you on top of your schedule right from the sill bar. Connect your calendar accounts to see upcoming events, get meeting reminders, and never miss an appointment.</value>
  </data>
  <data name="FeatureCalendar.TextProperty" xml:space="preserve">
    <value>View your calendar and upcoming events at a glance</value>
  </data>
  <data name="FeatureMeetings.TextProperty" xml:space="preserve">
    <value>Get meeting reminders and join video calls with one click</value>
  </data>
  <data name="FeatureWorldClocks.TextProperty" xml:space="preserve">
    <value>Pin world clocks to track time across time zones</value>
  </data>
  <data name="AccountsDescription.TextProperty" xml:space="preserve">
    <value>Connect your calendar accounts to start seeing events. You can add more accounts later in Settings.</value>
  </data>
  <data name="AddAccount.TextProperty" xml:space="preserve">
    <value>Add account</value>
  </data>
  <data name="NoAccountsMessage.TextProperty" xml:space="preserve">
