  </data>
  <data name="RemoveAccount.ToolTipService.ToolTipProperty" xml:space="preserve">
    <value>Remove account</value>
  </data>
  <data name="TravelTimeDescription.TextProperty" xml:space="preserve">
    <value>When enabled, WindowSill can estimate how long it takes to travel to your appointments and notify you when it's time to leave. This requires access to your location.</value>
  </data>
