  <data name="WelcomeDescription.TextProperty" xml:space="preserve">
    <value>दिनांक सुविधा आपको sill बार से सीधे अपने शेड्यूल की जानकारी देती है। आगामी इवेंट देखने, मीटिंग रिमाइंडर पाने और कोई अपॉइंटमेंट न चूकने के लिए अपने कैलेंडर खाते कनेक्ट करें।</value>
  </data>
  <data name="FeatureCalendar.TextProperty" xml:space="preserve">
    <value>अपना कैलेंडर और आगामी इवेंट एक नज़र में देखें</value>
  </data>
  <data name="FeatureMeetings.TextProperty" xml:space="preserve">
    <value>मीटिंग रिमाइंडर पाएं और एक क्लिक में वीडियो कॉल से जुड़ें</value>
  </data>
  <data name="FeatureWorldClocks.TextProperty" xml:space="preserve">
    <value>विभिन्न समय क्षेत्रों में समय ट्रैक करने के लिए विश्व घड़ियां पिन करें</value>
  </data>
  <data name="AccountsDescription.TextProperty" xml:space="preserve">
    <value>इवेंट देखना शुरू करने के लिए अपने कैलेंडर खाते कनेक्ट करें। आप बाद में सेटिंग्स में और खाते जोड़ सकते हैं।</value>
  </data>
  <data name="AddAccount.TextProperty" xml:space="preserve">
    <value>खाता जोड़ें</value>
  </data>
  <data name="NoAccountsMessage.TextProperty" xml:space="preserve">
    <value>अभी तक कोई खाता कनेक्ट नहीं है। आप इस चरण को छोड़ सकते हैं और बाद में खाते जोड़ सकते हैं।</value>
  </data>
  <data name="RemoveAccount.ToolTipService.ToolTipProperty" xml:space="preserve">
    <value>खाता हटाएं</value>
  </data>
  <data name="TravelTimeDescription.TextProperty" xml:space="preserve">
    <value>सक्षम होने पर, WindowSill आपकी अपॉइंटमेंट तक यात्रा समय का अनुमान लगा सकता है और निकलने का समय होने पर आपको सूचित कर सकता है। इसके लिए आपके स्थान तक पहुंच आवश्यक है।</value>
  </data>
  <data name="TravelTimeToggle.HeaderProperty" xml:space="preserve">
    <value>यात्रा समय सूचनाएं सक्षम करें</value>
  </data>
  <data name="LocationDenied.MessageProperty" xml:space="preserve">
    <value>स्थान पहुंच अस्वीकार कर दी गई। आप Windows सेटिंग्स में स्थान पहुंच सक्षम कर सकते हैं और बाद में दिनांक एक्सटेंशन सेटिंग्स में इस सुविधा को चालू कर सकते हैं।</value>
  </data>
  <data name="TravelTimeNoAccounts.TextProperty" xml:space="preserve">
    <value>कोई कैलेंडर खाता नहीं जोड़ा गया, इसलिए यात्रा समय सूचनाएं उपलब्ध नहीं हैं। खाता कनेक्ट करने के बाद आप दिनांक एक्सटेंशन सेटिंग्स में इस सुविधा को सक्षम कर सकते हैं।</value>
