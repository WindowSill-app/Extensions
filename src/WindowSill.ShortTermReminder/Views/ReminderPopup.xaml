<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.ShortTermReminder.Views.ReminderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="350"
    Opening="OnOpening"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Content area  -->
        <StackPanel
            Grid.Row="0"
            Padding="24"
            Spacing="12">

            <TextBox
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FontSize="20"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.Title, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                TextWrapping="Wrap" />

            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.RemainingTimeText, Mode=OneWay}" />
        </StackPanel>

        <!--  Footer  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">

            <Button
                MinWidth="80"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.DeleteCommand}"
                ElementSoundMode="FocusOnly">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE74D;" />
                    <TextBlock api:Uids.Uid="/WindowSill.ShortTermReminder/ReminderSillListViewPopupItem/Delete" />
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</api:SillPopupContent>
