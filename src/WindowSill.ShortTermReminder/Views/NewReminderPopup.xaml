<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.ShortTermReminder.Views.NewReminderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="350"
    Opening="OnOpening"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Content area  -->
        <Grid Grid.Row="0" Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,12"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/Title"
                FontSize="20"
                FontWeight="SemiBold"
                MaxLines="2"
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="1" Spacing="12">

                <TextBox
                    x:Name="ReminderTextBox"
                    api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/ReminderTextBox"
                    KeyDown="ReminderTextBox_KeyDown"
                    TabIndex="0"
                    Text="{x:Bind ViewModel.ReminderText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Orientation="Horizontal" Spacing="8">

                    <TextBlock VerticalAlignment="Center" api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/InHowLong" />

                    <NumberBox
                        x:Name="MinutesNumberBox"
                        KeyDown="ReminderTextBox_KeyDown"
                        LargeChange="10"
                        Maximum="90"
                        Minimum="1"
                        SmallChange="5"
                        SpinButtonPlacementMode="Compact"
                        TabIndex="1"
                        Value="{x:Bind ViewModel.Minutes, Mode=TwoWay}" />

                    <TextBlock VerticalAlignment="Center" api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/Minutes" />
                </StackPanel>

                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.ExactTimeText, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!--  Footer  -->
        <Border
            Grid.Row="1"
            Padding="24"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            XYFocusKeyboardNavigation="Enabled">

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/OkButton"
                    Command="{x:Bind ViewModel.OkCommand}"
                    ElementSoundMode="FocusOnly"
                    Style="{ThemeResource LargeAccentButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</api:SillPopupContent>
