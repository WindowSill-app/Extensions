<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.ShortTermReminder.Views.ReminderListItemContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WindowSill.ShortTermReminder.Views"
    mc:Ignorable="d">

    <StackPanel
        x:Name="RootPanel"
        Margin="{ThemeResource SillCommandContentMargin}"
        Orientation="Horizontal"
        Spacing="8">
        <Grid>
            <ProgressRing
                x:Name="CountdownRing"
                Width="32"
                Height="32"
                MinWidth="0"
                MinHeight="0"
                IsIndeterminate="False"
                Maximum="{x:Bind ViewModel.ProgressMaximum, Mode=OneWay}"
                Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />

            <TextBlock
                x:Name="InnerMinuteText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="{x:Bind ViewModel.InnerMinuteText, Mode=OneWay}" />
        </Grid>

        <TextBlock
            x:Name="OuterMinuteText"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Text="{x:Bind ViewModel.OuterMinuteText, Mode=OneWay}"
            Visibility="Collapsed" />

        <RichTextBlock
            x:Name="ReminderTitleText"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            views:RichTextBlockLinkBehavior.LinkedText="{x:Bind ViewModel.ReminderTitle, Mode=OneWay}"
            Visibility="Collapsed" />

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="OrientationStates">

                <VisualState x:Name="HorizontalLarge">
                    <!--  Default state: 32x32 ProgressRing, inner text visible  -->
                </VisualState>

                <VisualState x:Name="HorizontalMedium">
                    <VisualState.Setters>
                        <Setter Target="CountdownRing.Height" Value="16" />
                        <Setter Target="CountdownRing.Width" Value="16" />
                        <Setter Target="InnerMinuteText.Visibility" Value="Collapsed" />
                        <Setter Target="OuterMinuteText.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HorizontalSmall">
                    <VisualState.Setters>
                        <Setter Target="CountdownRing.Height" Value="12" />
                        <Setter Target="CountdownRing.Width" Value="12" />
                        <Setter Target="InnerMinuteText.Visibility" Value="Collapsed" />
                        <Setter Target="OuterMinuteText.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalLarge">
                    <VisualState.Setters>
                        <Setter Target="ReminderTitleText.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalMedium">
                    <VisualState.Setters>
                        <Setter Target="ReminderTitleText.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="VerticalSmall">
                    <VisualState.Setters>
                        <Setter Target="InnerMinuteText.Visibility" Value="Collapsed" />
                        <Setter Target="OuterMinuteText.Visibility" Value="Visible" />
                        <Setter Target="OuterMinuteText.Margin" Value="4,0,0,0" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </StackPanel>
</UserControl>
