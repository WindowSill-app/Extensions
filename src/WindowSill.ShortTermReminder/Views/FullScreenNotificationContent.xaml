<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.ShortTermReminder.Views.FullScreenNotificationContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WindowSill.ShortTermReminder.Views"
    mc:Ignorable="d">

    <Grid>
        <MediaPlayerElement
            x:Name="BackgroundMediaPlayer"
            Width="0"
            Height="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            AreTransportControlsEnabled="False"
            IsFullWindow="False"
            Loaded="BackgroundMediaPlayer_Loaded"
            Stretch="None" />

        <Border
            MaxWidth="1200"
            Margin="72"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource OverlayCornerRadius}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Reminder content  -->
                <StackPanel
                    Grid.Row="0"
                    Padding="36,40,36,40"
                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                    Spacing="16">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                    </StackPanel.ChildrenTransitions>

                    <TextBlock
                        HorizontalAlignment="Stretch"
                        api:Uids.Uid="/WindowSill.ShortTermReminder/FullScreenNotificationWindow/Title"
                        CharacterSpacing="200"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalTextAlignment="Center"
                        Style="{ThemeResource BodyTextBlockStyle}" />

                    <RichTextBlock
                        HorizontalAlignment="Stretch"
                        views:RichTextBlockLinkBehavior.LinkClickedCommand="{x:Bind ViewModel.OpenLinkAndDismissCommand}"
                        views:RichTextBlockLinkBehavior.LinkedText="{x:Bind ViewModel.ReminderTitle, Mode=OneTime}"
                        FontSize="40"
                        FontWeight="SemiBold"
                        MaxLines="5"
                        TextAlignment="Center"
                        TextTrimming="WordEllipsis"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!--  Actions footer  -->
                <Border
                    Grid.Row="1"
                    Padding="36,40,36,40"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0">

                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">

                        <Button Command="{x:Bind ViewModel.DismissCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE894;" />
                                <TextBlock api:Uids.Uid="/WindowSill.ShortTermReminder/FullScreenNotificationWindow/Dismiss" />
                            </StackPanel>
                        </Button>

                        <Button Command="{x:Bind ViewModel.SnoozeCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xF4BD;" />
                                <TextBlock api:Uids.Uid="/WindowSill.ShortTermReminder/FullScreenNotificationWindow/Snooze" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
