<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.ShortTermReminder.Views.ReminderPreviewFlyoutContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WindowSill.ShortTermReminder.Views"
    mc:Ignorable="d">

    <StackPanel Padding="8" Spacing="8">

        <RichTextBlock
            VerticalAlignment="Center"
            views:RichTextBlockLinkBehavior.LinkedText="{x:Bind ViewModel.ReminderTitle, Mode=OneWay}"
            FontSize="{ThemeResource BodyTextBlockFontSize}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />

        <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Text="{x:Bind ViewModel.PreviewTimeText, Mode=OneWay}" />
    </StackPanel>
</UserControl>
