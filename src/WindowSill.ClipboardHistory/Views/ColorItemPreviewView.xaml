<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.ClipboardHistory.Views.ColorItemPreviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        MinWidth="128"
        MinHeight="128"
        Padding="16"
        Background="{x:Bind ViewModel.BackgroundBrush, Mode=OneWay}">
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            HorizontalTextAlignment="Center"
            Foreground="{x:Bind ViewModel.ForegroundBrush, Mode=OneWay}"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            Text="{x:Bind ViewModel.ColorText, Mode=OneWay}" />
    </Border>
</UserControl>
