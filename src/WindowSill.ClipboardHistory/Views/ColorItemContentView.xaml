<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.ClipboardHistory.Views.ColorItemContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Margin="{ThemeResource SillCommandContentMargin}"
        Padding="4,2,4,2"
        Background="{x:Bind ViewModel.BackgroundBrush, Mode=OneWay}"
        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <TextBlock
            VerticalAlignment="Center"
            Foreground="{x:Bind ViewModel.ForegroundBrush, Mode=OneWay}"
            Text="{x:Bind ViewModel.ColorText, Mode=OneWay}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />
    </Border>
</UserControl>
